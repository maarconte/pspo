#!/usr/bin/env sh

MSG=$(cat "$1")

# Exempter les merge et revert commits
if echo "$MSG" | grep -qE "^(Merge|Revert)"; then
  exit 0
fi

# Vérifier la présence de l'ID ticket Linear
if ! echo "$MSG" | grep -qE "THA-[0-9]+"; then
  echo ""
  echo "Commit rejeté — ID ticket Linear manquant."
  echo "Format attendu : THA-XXX quelque part dans le message"
  echo "Exemples :"
  echo "  feat: THA-42 ajout page résultats"
  echo "  fix(auth): correction login [THA-7]"
  echo ""
  echo "Pour un commit WIP sans ticket : git commit --no-verify"
  echo ""
  exit 1
fi
